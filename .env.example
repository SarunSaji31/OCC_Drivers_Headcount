# Copy this file to .env and fill in real values. NEVER commit .env.
# Generate a SECRET_KEY with:
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*(-_=+)') for _ in range(64)))"

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local MySQL (production uses DATABASE_URL instead)
DB_NAME=staff_transport_db_pro
DB_USER=root
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306

# Email (Gmail SMTP with an App Password)
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=change-me-app-password
DEFAULT_FROM_EMAIL=you@gmail.com

TIME_ZONE=Asia/Dubai
